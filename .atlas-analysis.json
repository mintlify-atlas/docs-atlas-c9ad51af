    "GET/POST /docs — Documentation management",
    "GET/POST /builds — Build management",
    "GET/POST /releases — Release management",
    "GET/POST /todos — Personal todo management",
    "POST /bugs/:id/resolve — Resolve a bug",
    "POST /stories/:id/review — Review a story",
